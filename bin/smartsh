#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

if [[ -x "${HOME}/.local/share/smartsh/venv/bin/python" ]]; then
  exec "${HOME}/.local/share/smartsh/venv/bin/python" -m smartsh.shell
fi

if command -v python3 >/dev/null 2>&1; then
  exec python3 -m smartsh.shell
fi

echo "python3 not found. Please install Python 3.10+." >&2
exit 1
